import shutil
import os

path = '/root/.cache/kagglehub/datasets/kvnpatel/fruits-vegetable-detection-for-yolov4/versions/1'
source = f"{path}/test/test"
destination = "/kaggle/working/raw_data"

shutil.copytree(source, destination)

print("Copied successfully")

import os

base_path = "/kaggle/working/dataset"

os.makedirs(base_path + "/images/train", exist_ok=True)
os.makedirs(base_path + "/images/val", exist_ok=True)
os.makedirs(base_path + "/labels/train", exist_ok=True)
os.makedirs(base_path + "/labels/val", exist_ok=True)

print("Folders created")

import random
import shutil

raw_path = "/kaggle/working/raw_data"

all_files = os.listdir(raw_path)

# Get only image files
images = [f for f in all_files if f.endswith(".jpg")]

random.shuffle(images)

split_ratio = 0.8
split_index = int(len(images) * split_ratio)

train_images = images[:split_index]
val_images = images[split_index:]

for img in train_images:
    # Copy image
    shutil.copy(f"{raw_path}/{img}", f"{base_path}/images/train/{img}")

    # Copy corresponding label
    label = img.replace(".jpg", ".txt")
    shutil.copy(f"{raw_path}/{label}", f"{base_path}/labels/train/{label}")

for img in val_images:
    shutil.copy(f"{raw_path}/{img}", f"{base_path}/images/val/{img}")

    label = img.replace(".jpg", ".txt")
    shutil.copy(f"{raw_path}/{label}", f"{base_path}/labels/val/{label}")

print("Dataset split completed")

classes = set()

for file in images:
    name = file.split("_")[2]
    classes.add(name)

print(classes)

