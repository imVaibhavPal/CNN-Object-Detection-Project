!pip install ultralytics --quiet

from ultralytics import YOLO

model = YOLO("yolov8n.pt")

model.train(
    data="data.yaml",
    epochs=25,
    imgsz=416,
    batch=16
)

metrics = model.val()
print(metrics)

model.predict(
    source="/kaggle/working/dataset/images/val",
    save=True
)

